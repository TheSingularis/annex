# Directories to watch for new audiobooks and ebooks (inside container)
AUDIOBOOK_WATCH_PATH=/mnt/downloads/audiobooks
EBOOK_WATCH_PATH=/mnt/downloads/ebooks

# Audiobookshelf
ABS_HOST=http://localhost:13378
ABS_API_KEY=
ABS_AUDIOBOOK_LIBRARY_ID=
ABS_EBOOK_LIBRARY_ID=

# Library destination paths (inside container)
AUDIOBOOK_LIBRARY_PATH=/mnt/library/audiobooks
EBOOK_LIBRARY_PATH=/mnt/library/ebooks

# Database — defaults to /app/data/annex.db (bind-mounted from appdata)
# Only override if running outside Docker
# DATABASE_URL=sqlite:////app/data/annex.db

# Redis runs inside the same container — no need to change this
REDIS_URL=redis://localhost:6379/0

CONFIDENCE_THRESHOLD=0.85
POLL_INTERVAL_SECONDS=60
