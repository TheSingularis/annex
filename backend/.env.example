# Watch and library paths are configured in the web UI (Settings page).
# Set these only if you prefer env-var configuration — UI values take precedence.
# AUDIOBOOK_WATCH_PATH=/downloads/audiobooks
# EBOOK_WATCH_PATH=/downloads/ebooks
# AUDIOBOOK_LIBRARY_PATH=/library/audiobooks
# EBOOK_LIBRARY_PATH=/library/ebooks

# Redis runs inside the same container — no need to change this
REDIS_URL=redis://localhost:6379/0

CONFIDENCE_THRESHOLD=0.85
POLL_INTERVAL_SECONDS=60
