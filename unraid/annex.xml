<?xml version="1.0"?>
<Container version="2">
  <Name>Annex</Name>
  <Repository>ghcr.io/thesingularis/annex:latest</Repository>
  <Registry>https://github.com/TheSingularis/annex/pkgs/container/annex</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/TheSingularis/annex/issues</Support>
  <Project>https://github.com/TheSingularis/annex</Project>
  <Overview>Watches directories of unorganized ebooks and audiobooks and automatically organizes them into a clean Author/Title library structure using resolved metadata. Files are hardlinked so originals stay in place.</Overview>
  <Category>MediaApp:Books</Category>
  <WebUI>http://[IP]:[PORT:5000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/TheSingularis/annex/main/unraid/annex.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/TheSingularis/annex/main/unraid/icon.png</Icon>
  <ExtraParams>--label com.centurylinklabs.watchtower.enable=true</ExtraParams>
  <Requires/>

  <!-- Ports -->
  <Config
    Name="Web UI Port"
    Target="5000"
    Default="5000"
    Mode="tcp"
    Description="Annex web interface"
    Type="Port"
    Display="always"
    Required="true"
    Mask="false">5000</Config>

  <!-- Paths -->
  <Config
    Name="AppData"
    Target="/app/data"
    Default="/mnt/user/appdata/annex"
    Mode="rw"
    Description="Persistent storage for the Annex database."
    Type="Path"
    Display="always"
    Required="true"
    Mask="false">/mnt/user/appdata/annex</Config>

  <Config
    Name="Downloads"
    Target="/mnt/downloads"
    Default=""
    Mode="ro"
    Description="Root of your download directory. Annex watches subdirectories within this path."
    Type="Path"
    Display="always"
    Required="true"
    Mask="false"></Config>

  <Config
    Name="Library"
    Target="/mnt/library"
    Default=""
    Mode="rw"
    Description="Root of your organized book library. Must be on the same filesystem as Downloads for hardlinks to work."
    Type="Path"
    Display="always"
    Required="true"
    Mask="false"></Config>

  <!-- Watch paths -->
  <Config
    Name="Audiobook Watch Path"
    Target="AUDIOBOOK_WATCH_PATH"
    Default="/mnt/downloads/audiobooks"
    Mode=""
    Description="Path inside the container to watch for new audiobooks."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">/mnt/downloads/audiobooks</Config>

  <Config
    Name="Ebook Watch Path"
    Target="EBOOK_WATCH_PATH"
    Default="/mnt/downloads/ebooks"
    Mode=""
    Description="Path inside the container to watch for new ebooks."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">/mnt/downloads/ebooks</Config>

  <!-- Library destinations -->
  <Config
    Name="Audiobook Library Path"
    Target="AUDIOBOOK_LIBRARY_PATH"
    Default="/mnt/library/audiobooks"
    Mode=""
    Description="Path inside the container where organized audiobooks will be placed."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">/mnt/library/audiobooks</Config>

  <Config
    Name="Ebook Library Path"
    Target="EBOOK_LIBRARY_PATH"
    Default="/mnt/library/ebooks"
    Mode=""
    Description="Path inside the container where organized ebooks will be placed."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">/mnt/library/ebooks</Config>

  <!-- Import settings -->
  <Config
    Name="Confidence Threshold"
    Target="CONFIDENCE_THRESHOLD"
    Default="0.85"
    Mode=""
    Description="Metadata match confidence (0–1). Items below this score are queued for manual review."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">0.85</Config>

  <Config
    Name="Scan Interval (seconds)"
    Target="POLL_INTERVAL_SECONDS"
    Default="60"
    Mode=""
    Description="How often Annex scans watch directories for new files."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">60</Config>

  <!-- Audiobookshelf (optional) -->
  <Config
    Name="ABS Host"
    Target="ABS_HOST"
    Default=""
    Mode=""
    Description="[Optional] Audiobookshelf URL. When set, Annex triggers a library scan after each import."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false"></Config>

  <Config
    Name="ABS API Key"
    Target="ABS_API_KEY"
    Default=""
    Mode=""
    Description="[Optional] Audiobookshelf API key."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="true"></Config>

  <Config
    Name="ABS Audiobook Library ID"
    Target="ABS_AUDIOBOOK_LIBRARY_ID"
    Default=""
    Mode=""
    Description="[Optional] Audiobookshelf audiobook library ID."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false"></Config>

  <Config
    Name="ABS Ebook Library ID"
    Target="ABS_EBOOK_LIBRARY_ID"
    Default=""
    Mode=""
    Description="[Optional] Audiobookshelf ebook library ID."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false"></Config>
</Container>
